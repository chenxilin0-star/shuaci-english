.detail-page{padding-bottom:48rpx}.page-hero{padding:20rpx 0 28rpx}.eyebrow{font-size:24rpx;color:#2AAE67;font-weight:700;margin-bottom:8rpx}.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:20rpx;text-align:center}.stat-num{font-size:42rpx;font-weight:800;color:#2AAE67}.plan-line{margin-top:24rpx;background:#F8F9FA;border-radius:18rpx;padding:22rpx;color:#495057;font-size:26rpx}.section-title{font-size:32rpx;font-weight:700;margin:34rpx 0 18rpx}.section-card .h2{margin:0}.curve-row{display:flex;gap:20rpx;margin-bottom:28rpx}.dot{width:24rpx;height:24rpx;border-radius:50%;background:#2AAE67;margin-top:8rpx;box-shadow:0 0 0 8rpx #E8F7EF}.curve-main{flex:1}.curve-title{font-size:28rpx;font-weight:700}.curve-main .progress{margin:12rpx 0}@media (prefers-color-scheme: dark){.plan-line{background:#242428;color:#B5B5BD}}
