.home-page{padding-bottom:48rpx}.hero{background:linear-gradient(135deg,#2AAE67,#187A47);color:#fff;overflow:hidden;position:relative}.hero .title{color:#fff}.hero-top{display:flex;justify-content:space-between;align-items:flex-start;gap:24rpx}.hero-sub{font-size:26rpx;opacity:.86;margin-top:10rpx}.light{color:rgba(255,255,255,.82)}.hero-badge{width:92rpx;height:92rpx;border-radius:28rpx;background:rgba(255,255,255,.16);display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:800}.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20rpx;margin:36rpx 0 24rpx}.num{font-size:54rpx;font-weight:800;line-height:1}.today-row{display:flex;justify-content:space-between;font-size:26rpx;margin-bottom:14rpx}.hero-progress{background:rgba(255,255,255,.24)}.hero-progress .progress-bar{background:#fff}.section-title{font-size:32rpx;font-weight:800;margin:34rpx 0 18rpx}.quick-grid{margin-bottom:24rpx}.entry{text-align:left;font-weight:600}.entry-icon{width:76rpx;height:76rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;font-size:42rpx;margin-bottom:18rpx}.green{background:#E8F7EF}.purple-bg{background:#EFEAFE}.entry-title,.mini-title{font-size:32rpx;font-weight:800;margin-bottom:8rpx}.purple{border-top:8rpx solid #7B6AD7}.small-btn{min-width:150rpx}
button.small-btn{width:auto}.action-card .h2{margin:0 0 8rpx}.quote{font-size:30rpx;line-height:1.7;margin-bottom:12rpx}.seo-card{background:linear-gradient(135deg,#f8f9fa,#e8f7ef)}.seo-text{font-size:26rpx;color:#868e96;line-height:1.8}@media (prefers-color-scheme: dark){.green{background:#153522}.purple-bg{background:#2A2448}.seo-card{background:linear-gradient(135deg,#1e1e24,#153522)}}
