.grammar-page{padding-bottom:48rpx}.page-hero{padding:20rpx 0 24rpx}.eyebrow{font-size:24rpx;color:#2AAE67;font-weight:700;margin-bottom:8rpx}.search{margin:20rpx 0}.tabs{white-space:nowrap;margin:20rpx 0 28rpx}.cat{display:inline-flex;padding:14rpx 24rpx;border-radius:999rpx;background:#fff;color:#495057;margin-right:16rpx;font-size:26rpx;border:2rpx solid #E9ECEF}.cat.active{background:#2AAE67;color:#fff;border-color:#2AAE67}.layout{display:block}.topic-list{display:flex;overflow-x:auto;gap:16rpx;margin-bottom:24rpx}.topic-item{min-width:260rpx;background:#fff;border-radius:20rpx;padding:22rpx;border:2rpx solid #E9ECEF}.topic-item.active{border-color:#2AAE67;box-shadow:0 6rpx 20rpx rgba(42,174,103,.14)}.topic-title{font-size:30rpx;font-weight:700;margin-bottom:12rpx}.topic-meta{display:flex;flex-wrap:wrap;gap:8rpx;color:#868E96;font-size:22rpx}.detail-card{border-top:10rpx solid #2AAE67}.summary{font-size:30rpx;line-height:1.7;color:#495057;margin:18rpx 0}.block-title{font-size:28rpx;font-weight:700;margin:30rpx 0 14rpx;color:#212529}.content-box{background:#F8F9FA;border-radius:18rpx;padding:24rpx;line-height:1.7;color:#495057}.tip-line{line-height:1.8;color:#F0A030;font-size:26rpx}.example-card,.practice-card{background:#F8F9FA;border-radius:18rpx;padding:24rpx;line-height:1.7}.example-en{font-size:30rpx;font-weight:600;margin-bottom:10rpx}.question{font-size:30rpx;font-weight:700;margin-bottom:18rpx}.option{background:#fff;border:2rpx solid #E9ECEF;border-radius:16rpx;padding:20rpx;margin:14rpx 0}.option.active{border-color:#2AAE67;background:#E8F7EF;color:#187A47}.answer{color:#2AAE67;font-weight:700;margin:18rpx 0}.practice-actions{margin-top:18rpx}.learned-btn{margin-top:20rpx}@media (prefers-color-scheme: dark){.cat,.topic-item,.option{background:#1E1E24;border-color:#313135}.summary,.content-box{color:#B5B5BD}.block-title{color:#EAEAEC}.content-box,.example-card,.practice-card{background:#242428}.option.active{background:#153522}}
