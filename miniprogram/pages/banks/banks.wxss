.bank-page{padding-bottom:48rpx}.page-hero{padding:20rpx 0 28rpx}.eyebrow{font-size:24rpx;color:#2AAE67;font-weight:700;margin-bottom:8rpx}.bank-switch{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:20rpx;margin-bottom:24rpx}.bank-tab{min-width:0;box-sizing:border-box;background:#fff;border-radius:24rpx;padding:24rpx 20rpx;border:2rpx solid #E9ECEF;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04)}.bank-tab.active{border-color:#2AAE67;box-shadow:0 8rpx 28rpx rgba(42,174,103,.16)}.bank-tab.cet6.active{border-color:#7B6AD7;box-shadow:0 8rpx 28rpx rgba(123,106,215,.16)}.bank-row{display:flex;justify-content:space-between;gap:12rpx;align-items:flex-start}.bank-exam{font-size:36rpx;font-weight:800}.bank-name{font-size:24rpx;font-weight:600;margin:8rpx 0}.bank-percent{font-size:30rpx;font-weight:900;color:#2AAE67}.cet6 .bank-percent{color:#7B6AD7}.mini-progress{height:10rpx;margin:18rpx 0}.bank-meta{display:flex;gap:16rpx;flex-wrap:wrap;color:#868E96;font-size:22rpx}.focus-card{border-top:10rpx solid #2AAE67}.focus-card.cet6{border-top-color:#7B6AD7}.slogan{line-height:1.7;color:#495057;margin:18rpx 0 24rpx}.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:18rpx;margin:26rpx 0;text-align:center}.stat-num{font-size:40rpx;font-weight:800;color:#2AAE67}.focus-card.cet6 .stat-num{color:#7B6AD7}.path-line{background:#F8F9FA;border-radius:16rpx;padding:20rpx;color:#495057;font-size:26rpx}.detail-btn{margin-top:22rpx;width:100%;font-size:28rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.section-title{font-size:32rpx;font-weight:800;margin:34rpx 0 18rpx}.mode-list{display:flex;flex-direction:column;gap:18rpx}.mode-card{display:flex;align-items:center;gap:24rpx;margin-bottom:0}.mode-icon{width:76rpx;height:76rpx;border-radius:24rpx;background:#E8F7EF;display:flex;align-items:center;justify-content:center;font-size:40rpx}.mode-main{flex:1}.mode-title{font-size:32rpx;font-weight:800;margin-bottom:8rpx}.start-pill{background:#2AAE67;color:#fff;border-radius:999rpx;padding:12rpx 24rpx;font-size:24rpx;font-weight:700}.tip-card{background:#FFF6E8;border-radius:24rpx;padding:28rpx;margin-top:24rpx}.tip-title{font-weight:800;color:#F0A030;margin-bottom:10rpx}@media (prefers-color-scheme: dark){.bank-tab{background:#1E1E24;border-color:#313135}.path-line{background:#242428;color:#B5B5BD}.slogan{color:#B5B5BD}.tip-card{background:#2A2010}}
