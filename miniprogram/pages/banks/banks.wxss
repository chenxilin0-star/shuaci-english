.bank-page{padding-bottom:48rpx}.sr-only{height:1rpx;overflow:hidden;opacity:0}.page-hero{padding:20rpx 0 28rpx}.eyebrow{font-size:24rpx;color:#2AAE67;font-weight:700;margin-bottom:8rpx}.bank-switch{margin-bottom:24rpx}.bank-tab{background:#fff;border-radius:24rpx;padding:28rpx;border:2rpx solid #E9ECEF;box-shadow:0 2rpx 10rpx rgba(0,0,0,.04)}.bank-tab.active{border-color:#2AAE67;box-shadow:0 8rpx 28rpx rgba(42,174,103,.16)}.bank-tab.cet6.active{border-color:#7B6AD7;box-shadow:0 8rpx 28rpx rgba(123,106,215,.16)}.bank-exam{font-size:36rpx;font-weight:800}.bank-name{font-size:26rpx;font-weight:600;margin:8rpx 0}.focus-card{border-top:10rpx solid #2AAE67}.focus-card.cet6{border-top-color:#7B6AD7}.slogan{line-height:1.7;color:#495057;margin:18rpx 0 24rpx}.stats-row{display:flex;justify-content:space-between;margin:26rpx 0;text-align:center}.stat-num{font-size:44rpx;font-weight:800;color:#2AAE67}.focus-card.cet6 .stat-num{color:#7B6AD7}.path-line{background:#F8F9FA;border-radius:16rpx;padding:20rpx;color:#495057;font-size:26rpx}.detail-btn{margin-top:22rpx}.section-title{font-size:32rpx;font-weight:700;margin:34rpx 0 18rpx}.mode-card{display:flex;align-items:center;gap:24rpx}.mode-icon{width:72rpx;height:72rpx;border-radius:24rpx;background:#E8F7EF;display:flex;align-items:center;justify-content:center;font-size:40rpx}.mode-main{flex:1}.mode-main .h2{margin:0 0 8rpx}.start-pill{background:#2AAE67;color:#fff;border-radius:999rpx;padding:12rpx 24rpx;font-size:24rpx;font-weight:700}.tip-card{background:#FFF6E8;border-radius:24rpx;padding:28rpx;margin-top:24rpx}.tip-title{font-weight:700;color:#F0A030;margin-bottom:10rpx}@media (prefers-color-scheme: dark){.bank-tab{background:#1E1E24;border-color:#313135}.path-line{background:#242428;color:#B5B5BD}.slogan{color:#B5B5BD}.tip-card{background:#2A2010}}
