<view class="container"><view class="title">错题本</view><view wx:for="{{items}}" wx:key="itemId" class="card"><view class="row"><view><view class="h2">{{item.itemText}}</view><view class="muted">释义：{{item.meaning_cn}}</view><view class="bad">最近错答：{{item.wrongAnswer}}</view><view class="muted">错误次数：{{item.wrongCount}}</view></view><button class="btn btn-secondary small" bindtap="review" data-id="{{item.itemId}}">已复习</button></view></view><view wx:if="{{!items.length}}" class="card"><view class="muted">暂无错题。拼写错误后会自动加入这里。</view></view></view>
