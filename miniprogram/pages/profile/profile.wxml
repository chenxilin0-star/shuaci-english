<view class="container profile-page">
  <view class="card profile-hero">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{user.avatarUrl || pendingAvatarUrl}}" class="avatar-img" src="{{pendingAvatarUrl || user.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">刷</view>
    </button>
    <view class="profile-main">
      <input class="nickname-input" type="nickname" placeholder="点击填写微信昵称" value="{{pendingNickName}}" bindinput="onNicknameInput" />
      <view class="muted">使用微信头像昵称登录 · 学习记录同步云端</view>
    </view>
  </view>

  <view class="grid-2 stat-grid">
    <view class="card center"><view class="num">{{stats.streakDays || 0}}</view><view class="muted">连续学习</view></view>
    <view class="card center"><view class="num">{{stats.learnedWords || 0}}</view><view class="muted">已学词</view></view>
    <view class="card center"><view class="num">{{stats.masteredWords || 0}}</view><view class="muted">已掌握</view></view>
    <view class="card center"><view class="num">{{stats.mistakeCount || 0}}</view><view class="muted">待复盘</view></view>
  </view>

  <view class="card today-card">
    <view class="row"><view><view class="h2">今日学习</view><view class="muted">{{stats.todayLearned || 0}}/{{stats.todayGoal || 50}} 个任务</view></view><text class="tag">{{stats.completionPercent || 0}}%</text></view>
    <view class="progress"><view class="progress-bar" style="width: {{stats.completionPercent || 0}}%"></view></view>
  </view>

  <button class="btn btn-primary" bindtap="login">{{hasLogin ? '同步微信资料' : '微信头像昵称登录'}}</button>
  <button class="btn btn-secondary" bindtap="checkin">今日打卡</button>

  <view class="card menu-card">
    <view class="menu-row" bindtap="goFav"><view><text class="menu-icon">⭐</text><text>生词本 / 收藏</text></view><text class="muted">{{stats.favoriteCount || 0}} ›</text></view>
    <view class="menu-row" bindtap="goMistakes"><view><text class="menu-icon">🎯</text><text>错题本</text></view><text class="muted">{{stats.mistakeCount || 0}} ›</text></view>
    <view class="menu-row" bindtap="goBanks"><view><text class="menu-icon">📚</text><text>学习计划</text></view><text class="muted">›</text></view>
    <view class="menu-row" bindtap="goGrammar"><view><text class="menu-icon">🧩</text><text>语法专项</text></view><text class="muted">›</text></view>
  </view>

  <view class="card feedback-card">
    <view>
      <view class="h2">意见反馈</view>
      <view class="muted">联系微信：xym7563</view>
    </view>
    <button class="copy-btn" bindtap="copyFeedbackWechat">复制微信号</button>
  </view>
</view>
