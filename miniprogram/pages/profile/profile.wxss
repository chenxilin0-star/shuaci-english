.profile-page{padding-bottom:48rpx}.profile-hero{display:flex;align-items:center;gap:24rpx;background:linear-gradient(135deg,#fff,#E8F7EF)}.avatar{width:108rpx;height:108rpx;border-radius:32rpx;background:#2AAE67;color:#fff;display:flex;align-items:center;justify-content:center;font-size:48rpx;font-weight:800}.profile-main{flex:1}.center{text-align:center}.stat-grid{margin:24rpx 0}.num{font-size:52rpx;font-weight:800;color:#2AAE67}.today-card .h2{margin:0 0 8rpx}.today-card .progress{margin-top:22rpx}.btn{margin-bottom:22rpx}.menu-card{padding:8rpx 28rpx}.menu-row{display:flex;align-items:center;justify-content:space-between;padding:28rpx 0;border-bottom:1rpx solid #F1F3F5;font-size:30rpx}.menu-row:last-child{border-bottom:0}.menu-icon{margin-right:16rpx}@media (prefers-color-scheme: dark){.profile-hero{background:linear-gradient(135deg,#1E1E24,#153522)}.menu-row{border-color:#313135}}
