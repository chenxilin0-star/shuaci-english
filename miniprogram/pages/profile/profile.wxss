.profile-page{padding-bottom:48rpx}.profile-hero{display:flex;align-items:center;gap:24rpx;background:linear-gradient(135deg,#fff,#E8F7EF)}.avatar-btn{width:108rpx;height:108rpx;border-radius:32rpx;padding:0;margin:0;background:#2AAE67;overflow:hidden;display:flex;align-items:center;justify-content:center}.avatar-btn::after{border:0}.avatar-img{width:108rpx;height:108rpx;border-radius:32rpx}.avatar-placeholder{width:108rpx;height:108rpx;color:#fff;display:flex;align-items:center;justify-content:center;font-size:48rpx;font-weight:800}.profile-main{flex:1;min-width:0}.nickname-input{font-size:36rpx;font-weight:800;color:#1F2329;margin-bottom:8rpx}.center{text-align:center}.stat-grid{margin:24rpx 0}.num{font-size:52rpx;font-weight:800;color:#2AAE67}.today-card .h2{margin:0 0 8rpx}.today-card .progress{margin-top:22rpx}.btn{margin-bottom:22rpx}.menu-card{padding:8rpx 28rpx}.menu-row{display:flex;align-items:center;justify-content:space-between;padding:28rpx 0;border-bottom:1rpx solid #F1F3F5;font-size:30rpx}.menu-row:last-child{border-bottom:0}.menu-icon{margin-right:16rpx}.feedback-card{display:flex;align-items:center;justify-content:space-between;gap:24rpx;margin-top:24rpx}.copy-btn{margin:0;padding:0 28rpx;height:72rpx;line-height:72rpx;border-radius:999rpx;background:#E8F7EF;color:#15834B;font-size:26rpx;font-weight:700;white-space:nowrap}.copy-btn::after{border:0}@media (prefers-color-scheme: dark){.profile-hero{background:linear-gradient(135deg,#1E1E24,#153522)}.menu-row{border-color:#313135}.nickname-input{color:#F7F7F7}.copy-btn{background:#153522;color:#59D98E}}
