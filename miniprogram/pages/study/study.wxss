.study-page{padding-bottom:calc(48rpx + env(safe-area-inset-bottom));min-height:100vh;box-sizing:border-box}.study-hero{background:linear-gradient(135deg,#2AAE67,#187A47);border-radius:30rpx;padding:34rpx 30rpx;color:#fff;display:flex;justify-content:space-between;align-items:flex-start;gap:24rpx;box-shadow:0 12rpx 32rpx rgba(42,174,103,.22);margin-bottom:24rpx}.study-hero .title{color:#fff;font-size:44rpx}.eyebrow{font-size:24rpx;font-weight:800;color:rgba(255,255,255,.82);margin-bottom:8rpx}.hero-main{min-width:0;flex:1}.hero-desc{font-size:25rpx;line-height:1.5;color:rgba(255,255,255,.86);margin-top:10rpx;word-break:break-all}.counter-pill{flex-shrink:0;background:rgba(255,255,255,.18);border:1rpx solid rgba(255,255,255,.28);border-radius:999rpx;padding:12rpx 18rpx;font-size:26rpx;font-weight:800}.plan-card{padding:28rpx}.plan-head{display:flex;align-items:center;justify-content:space-between;gap:20rpx;margin-bottom:24rpx}.plan-title{font-size:32rpx;font-weight:800;color:#212529}.plan-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx}.plan-grid.has-supplement{grid-template-columns:repeat(4,1fr)}.plan-stat{border-radius:22rpx;padding:22rpx 10rpx;text-align:center;background:#F8F9FA}.new-stat{background:#E8F7EF}.review-stat{background:#EEF4FF}.mistake-stat{background:#FFF3E6}.supplement-stat{background:#F1F3F5}.stat-num{font-size:42rpx;font-weight:900;color:#2AAE67;line-height:1}.review-stat .stat-num{color:#4A78D8}.mistake-stat .stat-num{color:#F0A030}.supplement-stat .stat-num{color:#868E96}.stat-label{font-size:21rpx;color:#6C757D;margin-top:10rpx;white-space:nowrap}.word-card{min-height:520rpx;text-align:center;display:flex;flex-direction:column;justify-content:space-between;gap:24rpx;padding:34rpx 28rpx;border:2rpx solid #EEF1F3}.word-top{display:flex;justify-content:space-between;align-items:center;gap:18rpx}.plan-tag{margin:0}.word-main{padding:36rpx 0}.word-line{display:flex;align-items:center;justify-content:center;gap:18rpx;min-width:0}.word{font-size:76rpx;font-weight:900;color:#212529;line-height:1.15;word-break:break-word}.audio-btn{width:72rpx;height:72rpx;border-radius:50%;padding:0;margin:0;background:#E8F7EF;color:#187A47;font-size:34rpx;line-height:72rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0}.audio-btn::after,.action-btn::after,.tool-btn::after{border:0}.phonetic{color:#868E96;margin-top:16rpx;font-size:30rpx;min-height:40rpx}.front-hint{color:#ADB5BD;font-size:26rpx;padding:24rpx;background:#F8F9FA;border-radius:20rpx}.back{background:#F8F9FA;border-radius:22rpx;padding:26rpx;line-height:1.65}.meaning{font-size:34rpx;font-weight:800;margin:18rpx 0;color:#212529}.example{font-size:28rpx;line-height:1.7;margin-top:14rpx;color:#495057}.example-cn{margin-top:8rpx}.empty-card{text-align:center;padding:60rpx 36rpx}.empty-icon{font-size:72rpx;margin-bottom:16rpx}.action-bar{position:sticky;bottom:calc(18rpx + env(safe-area-inset-bottom));z-index:5;display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1.3fr);gap:18rpx;background:rgba(248,249,250,.92);backdrop-filter:blur(12rpx);padding:18rpx 0 0;width:100%;box-sizing:border-box;overflow:hidden}.action-btn{height:92rpx;width:100%;min-width:0;margin:0;padding:0;box-sizing:border-box;border-radius:24rpx;font-size:30rpx;font-weight:800;display:flex;align-items:center;justify-content:center}.action-btn.secondary{background:#E8F7EF;color:#187A47}.action-btn.primary{background:#2AAE67;color:#fff;box-shadow:0 10rpx 24rpx rgba(42,174,103,.22)}.tool-row{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:18rpx;margin-top:22rpx;box-sizing:border-box;overflow:hidden}.tool-btn{height:82rpx;width:100%;min-width:0;margin:0;padding:0;box-sizing:border-box;border-radius:22rpx;background:#fff;color:#495057;font-size:28rpx;border:1rpx solid #E9ECEF;display:flex;align-items:center;justify-content:center}@media (prefers-color-scheme: dark){.plan-title,.word,.meaning{color:#EAEAEC}.plan-stat,.front-hint,.back{background:#242428}.study-page .action-bar{background:rgba(18,18,18,.9)}.tool-btn{background:#1E1E24;border-color:#313135;color:#EAEAEC}.example{color:#B5B5BD}.word-card{border-color:#313135}.new-stat{background:#153522}.review-stat{background:#1B2944}.mistake-stat{background:#3A2812}.supplement-stat{background:#242428}}