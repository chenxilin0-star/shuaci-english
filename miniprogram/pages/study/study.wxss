.study-page{min-height:100vh;background:#F6F8F7;padding:28rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));box-sizing:border-box}.study-shell{max-width:750rpx;margin:0 auto}.study-header{display:flex;align-items:center;justify-content:space-between;gap:24rpx;margin-bottom:22rpx}.study-kicker{font-size:24rpx;font-weight:800;color:#2AAE67;margin-bottom:8rpx}.study-title{font-size:46rpx;font-weight:900;color:#17231B;letter-spacing:-1rpx}.study-count{flex-shrink:0;background:#17231B;color:#fff;border-radius:999rpx;padding:14rpx 22rpx;font-size:26rpx;font-weight:800}.mode-card{background:linear-gradient(135deg,#FFFFFF,#ECF8F1);border:1rpx solid #E1F1E8;border-radius:30rpx;padding:28rpx;margin-bottom:24rpx;box-shadow:0 10rpx 30rpx rgba(23,35,27,.06)}.mode-desc{font-size:26rpx;line-height:1.55;color:#4D5B52;margin-bottom:24rpx}.plan-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14rpx}.plan-grid.has-supplement{grid-template-columns:repeat(4,minmax(0,1fr))}.plan-stat{border-radius:22rpx;padding:20rpx 8rpx;text-align:center;box-sizing:border-box}.new-stat{background:#E8F7EF}.review-stat{background:#EEF4FF}.mistake-stat{background:#FFF3E6}.supplement-stat{background:#F1F3F5}.stat-num{font-size:40rpx;font-weight:900;line-height:1;color:#2AAE67}.review-stat .stat-num{color:#4A78D8}.mistake-stat .stat-num{color:#F0A030}.supplement-stat .stat-num{color:#868E96}.stat-label{font-size:21rpx;color:#6C757D;margin-top:10rpx;white-space:nowrap}.word-stage{margin-top:8rpx}.word-card{background:#fff;border-radius:38rpx;padding:34rpx 30rpx;min-height:600rpx;box-sizing:border-box;display:flex;flex-direction:column;justify-content:space-between;box-shadow:0 18rpx 48rpx rgba(23,35,27,.09);border:1rpx solid #EEF2EF}.word-card-top{display:flex;align-items:center;justify-content:space-between;gap:18rpx}.pill{display:inline-flex;align-items:center;justify-content:center;background:#E8F7EF;color:#187A47;border-radius:999rpx;padding:8rpx 18rpx;font-size:23rpx;font-weight:800}.flip-tip{color:#9AA4A0;font-size:24rpx}.word-content{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48rpx 0 36rpx}.word-line{display:flex;align-items:center;justify-content:center;gap:18rpx;width:100%;min-width:0}.word-text{font-size:82rpx;font-weight:900;color:#17231B;line-height:1.08;word-break:break-word;max-width:560rpx;text-align:center;letter-spacing:-2rpx}.audio-btn{width:76rpx;height:76rpx;line-height:76rpx;border-radius:50%;padding:0;margin:0;background:#2AAE67;color:#fff;font-size:34rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 8rpx 20rpx rgba(42,174,103,.25)}.audio-btn::after,.action-btn::after,.tool-btn::after{border:0}.phonetic-row{margin-top:26rpx;display:flex;align-items:center;justify-content:center;gap:12rpx;flex-wrap:wrap;background:#F6F8F7;border-radius:999rpx;padding:12rpx 22rpx}.phonetic-label{font-size:22rpx;font-weight:800;color:#2AAE67}.phonetic-text{font-size:30rpx;color:#5B655F;font-weight:600}.memory-hint{background:#F6F8F7;color:#9AA4A0;border-radius:24rpx;padding:24rpx;text-align:center;font-size:26rpx}.answer-panel{background:#F6F8F7;border-radius:28rpx;padding:28rpx;text-align:left}.pos-row{margin-bottom:14rpx}.light-pill{background:#fff;color:#495057}.meaning-text{font-size:36rpx;font-weight:900;color:#17231B;line-height:1.55;margin-bottom:18rpx}.example-en{font-size:28rpx;color:#495057;line-height:1.7;margin-top:14rpx}.example-cn{font-size:25rpx;color:#868E96;line-height:1.6;margin-top:8rpx}.empty-card{background:#fff;border-radius:32rpx;padding:70rpx 36rpx;text-align:center;box-shadow:0 12rpx 36rpx rgba(23,35,27,.06)}.empty-icon{font-size:76rpx;margin-bottom:20rpx}.empty-title{font-size:34rpx;font-weight:900;color:#17231B;margin-bottom:12rpx}.empty-desc{font-size:26rpx;color:#868E96;line-height:1.6}.action-bar{position:sticky;bottom:calc(18rpx + env(safe-area-inset-bottom));z-index:5;display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1.35fr);gap:18rpx;width:100%;box-sizing:border-box;overflow:hidden;background:rgba(246,248,247,.94);backdrop-filter:blur(14rpx);padding:20rpx 0 0;margin-top:26rpx}.action-btn{height:92rpx;width:100%;min-width:0;margin:0;padding:0;box-sizing:border-box;border-radius:26rpx;font-size:30rpx;font-weight:900;display:flex;align-items:center;justify-content:center}.action-btn.secondary{background:#fff;color:#187A47;border:2rpx solid #DDEFE5}.action-btn.primary{background:#2AAE67;color:#fff;box-shadow:0 10rpx 26rpx rgba(42,174,103,.25)}.tool-row{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:18rpx;margin-top:20rpx;box-sizing:border-box;overflow:hidden}.tool-btn{height:82rpx;width:100%;min-width:0;margin:0;padding:0;box-sizing:border-box;border-radius:24rpx;background:#fff;color:#495057;font-size:28rpx;border:1rpx solid #E6ECE8;display:flex;align-items:center;justify-content:center}@media (prefers-color-scheme: dark){.study-page{background:#121212}.study-title,.word-text,.meaning-text,.empty-title{color:#EAEAEC}.mode-card,.word-card,.empty-card,.tool-btn,.action-btn.secondary{background:#1E1E24;border-color:#313135}.mode-desc,.example-en{color:#B5B5BD}.word-card{box-shadow:none}.phonetic-row,.memory-hint,.answer-panel{background:#242428}.new-stat{background:#153522}.review-stat{background:#1B2944}.mistake-stat{background:#3A2812}.supplement-stat{background:#242428}.action-bar{background:rgba(18,18,18,.9)}}
