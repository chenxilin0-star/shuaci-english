.about-page{padding-bottom:48rpx}.page-hero{text-align:center;padding:48rpx 0 32rpx}.brand{font-size:52rpx;font-weight:800;color:#2AAE67;margin-bottom:12rpx}.slogan{font-size:28rpx;color:#868e96;line-height:1.6}.intro-card .seo-text{font-size:28rpx;color:#495057;line-height:1.8;margin-top:16rpx}.section-title{font-size:32rpx;font-weight:800;margin:40rpx 0 20rpx}.feature-list{display:flex;flex-direction:column;gap:20rpx}.feature-card{display:flex;align-items:flex-start;gap:20rpx;padding:28rpx}.feature-icon{font-size:44rpx;width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;background:#E8F7EF;border-radius:16rpx;flex-shrink:0}.feature-main{flex:1;min-width:0}.feature-title{font-size:30rpx;font-weight:700;margin-bottom:8rpx}.mode-card{padding:16rpx 28rpx}.mode-row{padding:24rpx 0;border-bottom:1rpx solid #F1F3F5}.mode-row:last-child{border-bottom:0}.mode-tag{display:inline-block;padding:6rpx 16rpx;border-radius:999rpx;background:#E8F7EF;color:#187A47;font-size:24rpx;font-weight:600;margin-bottom:10rpx}.audience-card{padding:16rpx 28rpx}.audience-item{display:flex;gap:12rpx;padding:16rpx 0;font-size:28rpx;color:#495057;border-bottom:1rpx solid #F1F3F5}.audience-item:last-child{border-bottom:0}.bullet{color:#2AAE67;font-weight:700}.seo-card .tag-list{display:flex;flex-wrap:wrap;gap:12rpx;margin:20rpx 0}.seo-tag{display:inline-flex;padding:8rpx 18rpx;border-radius:999rpx;background:#F1F3F5;color:#495057;font-size:24rpx}.seo-paragraph{font-size:26rpx;color:#868e96;line-height:1.8;margin-top:16rpx}.footer{text-align:center;margin:48rpx 0 24rpx}.footer .muted{margin-bottom:8rpx}.back-btn{margin-top:24rpx}@media (prefers-color-scheme: dark){.feature-icon{background:#153522}.seo-tag{background:#2A2A32;color:#B5B5BD}}
