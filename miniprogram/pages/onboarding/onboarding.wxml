<view class="container onboarding-page">
  <view class="step-card">
    <view class="step-num">{{step+1}} / {{4}}</view>
    <view class="title">{{current.title}}</view>
    <view class="muted">{{current.desc}}</view>
  </view>
  <button class="btn btn-primary" bindtap="next">{{step >= 3 ? '开始刷词' : '下一步'}}</button>
  <button class="plain" bindtap="skip">跳过引导</button>
</view>
