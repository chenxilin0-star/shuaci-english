page { background: #F8F9FA; color: #212529; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif; }
.container { padding: 32rpx; max-width: 750rpx; margin: 0 auto; box-sizing: border-box; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); margin-bottom: 24rpx; }
.primary { color: #2AAE67; }
.btn { height: 88rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 30rpx; border: none; margin: 0; padding: 0 28rpx; box-sizing: border-box; }
button.btn { width: 100%; }
.btn::after { border: none; }
.btn-primary { background: #2AAE67; color: #fff; }
.btn-secondary { background: #E8F7EF; color: #187A47; }
.plain { background: transparent; color: #868E96; font-size: 28rpx; height: auto; margin: 0; padding: 20rpx 0; box-sizing: border-box; }
button.plain { width: 100%; }
.plain::after { border: none; }
.muted { color: #868E96; font-size: 24rpx; }
.title { font-size: 44rpx; font-weight: 700; color: #212529; }
.h2 { font-size: 36rpx; font-weight: 600; margin: 24rpx 0; }
.row { display:flex; align-items:center; justify-content:space-between; gap: 20rpx; }
.grid-2 { display:grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.tag { display:inline-flex; padding: 6rpx 14rpx; border-radius: 999rpx; font-size: 22rpx; background:#E8F7EF; color:#187A47; margin-right: 10rpx; }
.progress { height: 12rpx; background: #C5EBD6; border-radius: 999rpx; overflow: hidden; }
.progress-bar { height: 100%; background: #2AAE67; border-radius: 999rpx; }
.input { background:#F1F3F5; border-radius:16rpx; padding:24rpx; font-size:32rpx; }
@media (prefers-color-scheme: dark) { page { background:#121212; color:#EAEAEC; } .card { background:#1E1E24; } .title { color:#EAEAEC; } .input { background:#2A2A32; color:#EAEAEC; } }
